# Godot 4+ specific
.godot/
*.translation
export.cfg
export_presets.cfg

# Host project files. This repo distributes ONLY the addon — if you open this
# folder as a Godot project (for dev/testing), Godot will auto-create these.
# They stay local and don't ship with the addon.
project.godot
icon.svg
icon.svg.import
# Scratch .tres / scenes created while dev-testing in the project root.
/*.tres
/*.tscn
/*.gd

# Internal working files (roadmap, notes, scratch)
/temp/

# System / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Build artifacts
/android/
/build/
*.zip

# Local screen recordings — embed showcase videos via GitHub upload
# (drag into the README web editor / an Issue → user-attachments URL), not the repo.
*.mp4
*.mov
*.webm
